@page "/"

<PageTitle>HabitTracker — Build Better Habits</PageTitle>

<div class="hero-section text-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold mb-3">Track Your Habits.<br/>Build Your Future.</h1>
                <p class="lead text-muted mb-4">
                    HabitTracker helps you build consistent routines, measure your progress,
                    and stay motivated every day.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/register" class="btn btn-primary btn-lg px-4">Get Started Free</a>
                    <a href="/login" class="btn btn-outline-secondary btn-lg px-4">Sign In</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="feature-icon mb-3">&#128203;</div>
                <h5 class="fw-semibold">Track Daily &amp; Weekly Habits</h5>
                <p class="text-muted">Create custom habits with daily or weekly frequency and mark them complete each day.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="feature-icon mb-3">&#128200;</div>
                <h5 class="fw-semibold">Visualise Your Progress</h5>
                <p class="text-muted">See weekly completion rates, streaks, and per-habit progress bars on your dashboard.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="feature-icon mb-3">&#128293;</div>
                <h5 class="fw-semibold">Keep Your Streak Alive</h5>
                <p class="text-muted">Build momentum with a streak counter that motivates you to stay consistent.</p>
            </div>
        </div>
    </div>
</div>
